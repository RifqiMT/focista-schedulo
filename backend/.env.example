# Optional: lock CORS to your deployed frontend origin (e.g. Vercel production URL).
# REQUIRED when NODE_ENV=production or FOCISTA_ENV=production.
# FRONTEND_ORIGIN=https://your-app.vercel.app

# HTTP port (default 4000)
# PORT=4000

# Persistence backend:
# - fs (default local): backend/data/*.runtime.json
# - neon: Neon Postgres Free (row-per-task)
# Leave unset for auto: neon when DATABASE_URL is present, otherwise fs.
# STORAGE_BACKEND=fs
# STORAGE_BACKEND=neon

# Neon Postgres (create a Free project at https://neon.tech — use the pooled connection string)
# DATABASE_URL=postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Optional unpooled URL for one-off migrations/admin tools:
# DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# Optional Neon Free tuning:
# NEON_FRESHNESS_TTL_MS=2000
# NEON_TRANSFER_TTL_HOURS=2
# NEON_STATEMENT_TIMEOUT_MS=15000

# Productivity Summary (Groq LLM + optional Tavily web enrich). Server-only — never expose as VITE_*.
# GROQ_API_KEY=gsk_...
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
# TAVILY_API_KEY=tvly-...
