# Optional: lock CORS to your deployed frontend origin (e.g. Vercel production URL).
# REQUIRED when NODE_ENV=production or FOCISTA_ENV=production.
# FRONTEND_ORIGIN=https://your-app.vercel.app

# HTTP port (default 4000)
# PORT=4000

# Persistence backend:
# - fs (default local): backend/data/*.runtime.json
# - vercel-blob: Vercel Blob object storage (Hobby free tier; no Redis/Mongo)
# Leave unset for auto: vercel-blob when BLOB_READ_WRITE_TOKEN (or OIDC) is present.
# STORAGE_BACKEND=fs
# STORAGE_BACKEND=vercel-blob

# Vercel Blob (create a Private Blob store in the Vercel dashboard → Storage)
# Required for STORAGE_BACKEND=vercel-blob when the API runs outside Vercel.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# Optional overrides:
# BLOB_RUNTIME_PREFIX=focista-schedulo/runtime/
# BLOB_ACCESS=private
# BLOB_STORE_ID=store_...   # used with VERCEL_OIDC_TOKEN when API runs on Vercel
